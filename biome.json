{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": ["**/*.js", "**/*.json"]
  },
  "formatter": {
    "enabled": true,
    "includes": ["package.json", "package-lock.json", "biome.json", "tests/**/*.js"],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "includes": ["**/*.js", "**/*.json"],
    "rules": {
      "recommended": true,
      "complexity": {
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "correctness": {
        "noInnerDeclarations": "off"
      },
      "style": {
        "useTemplate": "off"
      },
      "suspicious": {
        "noRedundantUseStrict": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none"
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
